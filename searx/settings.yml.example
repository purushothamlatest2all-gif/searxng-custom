plugins:
  searx.plugins.ahmia_filter.SXNGPlugin:
    active: true
  searx.plugins.calculator.SXNGPlugin:
    active: true
  searx.plugins.hash_plugin.SXNGPlugin:
    active: true
  searx.plugins.hostnames.SXNGPlugin:
    active: true
  searx.plugins.infinite_scroll.SXNGPlugin:
    active: false
  searx.plugins.oa_doi_rewrite.SXNGPlugin:
    active: false
  searx.plugins.overview.SXNGPlugin:
    active: true
  searx.plugins.self_info.SXNGPlugin:
    active: true
  searx.plugins.time_zone.SXNGPlugin:
    active: true
  searx.plugins.tor_check.SXNGPlugin:
    active: false
  searx.plugins.tracker_url_remover.SXNGPlugin:
    active: true
  searx.plugins.unit_converter.SXNGPlugin:
    active: true
  searx.plugins.useragent_rotator.SXNGPlugin:
    active: true
preferences:
  lock: []
result_proxy:
  key: null
  url: null
search:
  autocomplete: google
  autocomplete_min: 4
  ban_time_on_fail: 5
  default_lang: auto
  favicon_resolver: ''
  formats:
  - html
  - json
  - csv
  - rss
  max_ban_time_on_fail: 120
  safe_search: 0
  suspended_times:
    SearxEngineAccessDenied: 180
    SearxEngineCaptcha: 3600
    SearxEngineTooManyRequests: 180
    cf_SearxEngineAccessDenied: 86400
    cf_SearxEngineCaptcha: 1296000
    recaptcha_SearxEngineCaptcha: 604800
server:
  base_url: https://search.latest2all.com/
  bind_address: 127.0.0.1
  default_http_headers:
    Referrer-Policy: no-referrer
    X-Content-Type-Options: nosniff
    X-Download-Options: noopen
    X-Robots-Tag: noindex, nofollow
  http_protocol_version: '1.0'
  image_proxy: false
  limiter: true
  method: POST
  port: 8888
  public_instance: true
  secret_key: "ultrasecretkey_change_this_to_a_random_string"
ui:
  center_alignment: false
  default_locale: ''
  default_theme: simple
  hotkeys: default
  query_in_title: false
  search_on_category_select: true
  static_path: ''
  templates_path: ''
  theme_args:
    simple_style: auto
  url_formatting: pretty
valkey:
  url: false

# Statistics configuration
stats:
  enabled: true
  # Store stats in Redis for persistence
  storage: redis
  # How often to flush stats (in seconds)
  flush_interval: 3600

# Redis configuration for statistics and rate limiting
redis:
  url: redis://localhost:6379/0
